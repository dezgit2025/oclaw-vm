        </mxCell>

        <!-- SKILL.md path (on-demand) -->
        <mxCell id="s4-skill" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;SKILL.md (On-Demand)&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Deep recall pipeline&lt;br&gt;&lt;br&gt;Triggered by memory queries&lt;br&gt;Topic-specific search&lt;br&gt;More results returned&lt;br&gt;&lt;br&gt;&lt;b&gt;Full semantic + keyword search&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;gradientColor=#E1BEE7;gradientDirection=south;strokeColor=#9C27B0;strokeWidth=2;fontColor=#4A148C;fontSize=11;arcSize=10;shadow=1;spacingTop=3;spacingBottom=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="1700" width="260" height="210" as="geometry"/>
        </mxCell>

        <!-- Fallback chain -->
        <mxCell id="s4-fallback" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;Fallback Chain&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;1. Azure AI Search (hybrid)&lt;br&gt;&amp;darr;&lt;br&gt;2. SQLite FTS5 (local)&lt;br&gt;&amp;darr;&lt;br&gt;3. Skip silently&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#9C27B0;strokeWidth=2;fontColor=#4A148C;fontSize=12;arcSize=10;shadow=1;spacingTop=5;spacingBottom=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="1700" width="220" height="140" as="geometry"/>
        </mxCell>

        <!-- BarneyBot output -->
        <mxCell id="s4-output" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;BarneyBot&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;(ClawBot)&lt;/font&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Context-aware responses&lt;br&gt;with recalled memories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;gradientColor=#BA68C8;gradientDirection=south;strokeColor=#6A1B9A;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;arcSize=10;shadow=1;spacingTop=5;spacingBottom=5;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1730" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- Stage 4 schedule -->
        <mxCell id="s4-schedule" value="&lt;b&gt;Runs:&lt;/b&gt; Every conversation turn" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#6A1B9A;fontStyle=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="140" y="1920" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrows within Stage 4 -->
        <mxCell id="s4-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6A1B9A;strokeWidth=3;endArrow=blockThin;endFill=1;shadow=1;" edge="1" source="s4-hook" target="s4-output" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="270" y="1950"/>
              <mxPoint x="980" y="1950"/>
              <mxPoint x="980" y="1785"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="s4-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6A1B9A;strokeWidth=3;endArrow=blockThin;endFill=1;shadow=1;" edge="1" source="s4-skill" target="s4-output" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="570" y="1960"/>
              <mxPoint x="975" y="1960"/>
              <mxPoint x="975" y="1800"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="s4-arrow-fallback1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9C27B0;strokeWidth=2;endArrow=blockThin;endFill=1;dashed=1;dashPattern=8 4;" edge="1" source="s4-hook" target="s4-fallback" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s4-fallback-label" value="&lt;font style=&quot;font-size: 10px; color: #6A1B9A;&quot;&gt;uses fallback chain&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" vertex="1" connectable="0" parent="s4-arrow-fallback1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- LEGEND / SUMMARY TABLE                                        -->
        <!-- ============================================================ -->

        <!-- Legend container -->
        <mxCell id="legend-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#455A64;strokeWidth=2;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="2100" width="1200" height="420" as="geometry"/>
        </mxCell>

        <!-- Legend title -->
        <mxCell id="legend-title" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Pipeline Summary &amp;amp; Cron Schedule&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37474F;gradientColor=#546E7A;gradientDirection=south;strokeColor=#263238;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=18;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="2115" width="1160" height="45" as="geometry"/>
        </mxCell>

        <!-- Legend row 1: UNDERSTAND -->
        <mxCell id="leg-s1-color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#E65100;strokeWidth=2;arcSize=20;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="2180" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="leg-s1-text" value="&lt;b&gt;Stage 1: UNDERSTAND&lt;/b&gt; &amp;mdash; &lt;code&gt;smart_extractor.py sweep&lt;/code&gt; via GPT-5.2 extracts atomic facts from session logs. 5-gate quality filter. Daily 20:15 UTC." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#37474F;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="195" y="2180" width="720" height="40" as="geometry"/>
        </mxCell>

        <!-- Legend row 2: STORE -->
        <mxCell id="leg-s2-color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=#2E7D32;strokeWidth=2;arcSize=20;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="2235" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="leg-s2-text" value="&lt;b&gt;Stage 2: STORE&lt;/b&gt; &amp;mdash; SQLite (&lt;code&gt;~/.claude-memory/memory.db&lt;/code&gt;) is the write store and source of truth. Plain text only. Immediate after extraction." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#37474F;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="195" y="2235" width="720" height="40" as="geometry"/>
        </mxCell>

        <!-- Legend row 3: EMBED -->
        <mxCell id="leg-s3-color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;strokeColor=#1565C0;strokeWidth=2;arcSize=20;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="2290" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="leg-s3-text" value="&lt;b&gt;Stage 3: EMBED&lt;/b&gt; &amp;mdash; Azure AI Search auto-vectorizes (text-embedding-3-large, 3072d). Hybrid: Vector + BM25 + Semantic Ranker. Daily 20:35 UTC." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#37474F;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="195" y="2290" width="720" height="40" as="geometry"/>
        </mxCell>

        <!-- Legend row 4: RECALL -->
        <mxCell id="leg-s4-color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;strokeColor=#6A1B9A;strokeWidth=2;arcSize=20;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="2345" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="leg-s4-text" value="&lt;b&gt;Stage 4: RECALL&lt;/b&gt; &amp;mdash; Hook (always-on, ~0.13s, 3-5 facts) + SKILL.md (deep recall). Fallback: Azure AI Search &amp;rarr; SQLite FTS5 &amp;rarr; skip." style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#37474F;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="195" y="2345" width="720" height="40" as="geometry"/>
        </mxCell>

        <!-- Cron schedule table -->
        <mxCell id="leg-cron-title" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;Cron Schedule (UTC)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#263238;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="2405" width="160" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="leg-cron-row1" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;code&gt;10 20 * * *&lt;/code&gt; &amp;nbsp; session_format_watchdog.py &amp;nbsp; &lt;i&gt;(validate session format before extraction)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#455A64;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="2435" width="520" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg-cron-row2" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;code&gt;15 20 * * *&lt;/code&gt; &amp;nbsp; smart_extractor.py sweep &amp;nbsp; &lt;i&gt;(extract facts from new sessions)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#455A64;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="2455" width="470" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg-cron-row3" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;code&gt;35 20 * * *&lt;/code&gt; &amp;nbsp; memory_bridge.py sync &amp;nbsp; &lt;i&gt;(sync SQLite to Azure AI Search)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#455A64;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="2475" width="430" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg-cron-row4" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;code&gt;0 3 * * *&lt;/code&gt; &amp;nbsp;&amp;nbsp; Log rotation &amp;nbsp; &lt;i&gt;(keep 7 days of extraction/sync logs)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontColor=#455A64;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="2495" width="410" height="25" as="geometry"/>
        </mxCell>

        <!-- Key principle callout -->
        <mxCell id="leg-principle" value="&lt;b style=&quot;font-size: 13px;&quot;&gt;Key Principle&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Each stage has ONE job.&lt;br&gt;&lt;b&gt;UNDERSTAND&lt;/b&gt; extracts. &lt;b&gt;STORE&lt;/b&gt; persists.&lt;br&gt;&lt;b&gt;EMBED&lt;/b&gt; vectorizes. &lt;b&gt;RECALL&lt;/b&gt; retrieves.&lt;br&gt;&lt;br&gt;No stage crosses into another's territory.&lt;br&gt;SQLite = write path. Azure = read path.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;fontColor=#37474F;fontSize=11;arcSize=10;shadow=1;spacingTop=3;spacingBottom=5;" vertex="1" parent="1">
          <mxGeometry x="940" y="2180" width="240" height="185" as="geometry"/>
        </mxCell>

        <!-- Version/date label -->
        <mxCell id="version-label" value="&lt;font style=&quot;font-size: 10px; color: #9E9E9E;&quot;&gt;BarneyBot Brain Architecture v1 | Created 2026-02-23 | oclaw2026linux&lt;/font&gt;" style="text;html=1;align=right;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="2530" width="480" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

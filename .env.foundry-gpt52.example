# Azure OpenAI / AI Foundry (Entra ID auth)
# Copy to .env.foundry-gpt52 and fill in ONE auth method below.

AZURE_OPENAI_ENDPOINT=https://pitchbook-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2024-12-01-preview
MAX_COMPLETION_TOKENS=512

# Option A: Service principal (client secret)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Option B: Managed identity (Azure VM/Container Apps/etc.)
# (Usually no env vars required)

# Option C: Workload identity (federated token)
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_FEDERATED_TOKEN_FILE=

# next-ai-draw-io Environment Configuration
# Copy this file to .env.drawio and fill in your actual values

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Configuration
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5

# Port Configuration (change if 3000 is already in use)
PORT=3000

# next-ai-draw-io with Azure OpenAI Configuration
# Copy this file to .env.azure-drawio and adjust if needed

# Azure OpenAI Configuration
AI_PROVIDER=azure
AI_MODEL=gpt-5.2
AZURE_API_KEY=
AZURE_BASE_URL=https://pitchbook-resource.openai.azure.com

# Port Configuration (change if 3000 is already in use)
PORT=3000

# Optional: Temperature (0=deterministic/recommended for diagrams, 1=creative)
TEMPERATURE=0

# Optional: Reasoning configuration (for advanced reasoning models)
# AZURE_REASONING_EFFORT=medium  # Options: low, medium, high
# AZURE_REASONING_SUMMARY=brief   # Options: none, brief, detailed
